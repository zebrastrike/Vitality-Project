generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  addresses     Address[]
  reviews       Review[]
  affiliate     Affiliate?
  sessions      Session[]
  accounts      Account[]
  cartItems     CartItem[]
  orgMemberships OrgMember[]
  orgClients     OrgClient[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  AFFILIATE
  ADMIN
}

// ─── Organizations & Tenancy ────────────────────────────────────────────────

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  type      OrgType
  status    OrgStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  locations     Location[]
  members       OrgMember[]
  clients       OrgClient[]
  pricingPlans  PricingPlan[]
  orders        Order[]

  @@map("organizations")
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  zip            String?
  phone          String?
  commissionRate Float    @default(0.10)
  pricingPlanId  String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingPlan    PricingPlan? @relation(fields: [pricingPlanId], references: [id])
  devices        LocationDevice[]
  orders         Order[]
  clients        OrgClient[]
  members        OrgMember[]
  commissions    OrderCommission[]

  @@unique([organizationId, slug])
  @@map("locations")
}

model OrgMember {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           OrgMemberRole
  locationId     String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  location       Location?    @relation(fields: [locationId], references: [id])

  @@unique([organizationId, userId])
  @@map("org_members")
}

model OrgClient {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  locationId     String?
  status         ClientStatus @default(ACTIVE)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  location       Location?    @relation(fields: [locationId], references: [id])
  orders         Order[]

  @@unique([organizationId, userId])
  @@map("org_clients")
}

model LocationDevice {
  id         String   @id @default(cuid())
  locationId String
  name       String
  apiKey     String   @unique
  lastSeenAt DateTime?

  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("location_devices")
}

model PricingPlan {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  baseDiscountPct Float?

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  overrides      ProductPriceOverride[]
  locations      Location[]

  @@unique([organizationId, name])
  @@map("pricing_plans")
}

model ProductPriceOverride {
  id            String   @id @default(cuid())
  pricingPlanId String
  productId     String
  price         Int

  pricingPlan   PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([pricingPlanId, productId])
  @@map("product_price_overrides")
}

model OrderCommission {
  id          String            @id @default(cuid())
  orderId     String
  locationId  String
  amount      Int
  status      CommissionStatus @default(PENDING)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([orderId, locationId])
  @@map("order_commissions")
}

enum OrgType {
  GYM
  CLINIC
  DOCTOR_OFFICE
  OTHER
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum OrgMemberRole {
  OWNER
  ADMIN
  STAFF
  COACH
  DOCTOR
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Products ────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String        @db.Text
  shortDesc     String?
  price         Int           // in cents
  comparePrice  Int?          // original/strikethrough price
  salePrice     Int?          // overrides price when set (sale event)
  cost          Int?          // cost of goods
  sku           String?       @unique
  barcode       String?
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  inventory     Int           @default(0)
  trackInventory Boolean      @default(true)
  weight        Float?        // in grams
  status        ProductStatus @default(DRAFT)
  featured      Boolean       @default(false)
  seoTitle      String?
  seoDesc       String?
  tags          String[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  reviews       Review[]
  priceOverrides ProductPriceOverride[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("products")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String  // e.g. "10mg / 30 vials"
  sku       String?
  price     Int     // in cents
  inventory Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// ─── Cart ────────────────────────────────────────────────────────────────────

model CartItem {
  id        String  @id @default(cuid())
  userId    String?
  sessionId String? // for guest carts
  productId String
  variantId String?
  quantity  Int     @default(1)
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_items")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  email           String
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?     // stripe | crypto
  paymentId       String?     // stripe payment intent or crypto charge id
  subtotal        Int         // in cents
  discount        Int         @default(0)
  shipping        Int         @default(0)
  tax             Int         @default(0)
  total           Int         // in cents
  discountCode    String?
  notes           String?
  items           OrderItem[]
  shippingAddress Address?    @relation(fields: [shippingAddressId], references: [id])
  shippingAddressId String?
  trackingNumber  String?
  trackingUrl     String?
  affiliateCode   String?
  affiliateId     String?
  organizationId String?
  locationId     String?
  clientId       String?
  salesChannel   OrderChannel @default(DIRECT)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  location       Location?     @relation(fields: [locationId], references: [id])
  client         OrgClient?    @relation(fields: [clientId], references: [id])
  commissions    OrderCommission[]

  @@map("orders")
  @@index([organizationId])
  @@index([locationId])
  @@index([clientId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum OrderChannel {
  DIRECT
  LOCATION_KIOSK
  CLIENT_PORTAL
  ADMIN
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String  // snapshot at time of purchase
  sku       String?
  price     Int     // in cents, snapshot
  quantity  Int
  total     Int     // in cents
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── Addresses ───────────────────────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  name       String
  line1      String
  line2      String?
  city       String
  state      String
  zip        String
  country    String  @default("US")
  phone      String?
  isDefault  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@map("addresses")
}

// ─── Discount Codes ──────────────────────────────────────────────────────────

model DiscountCode {
  id          String       @id @default(cuid())
  code        String       @unique
  type        DiscountType @default(PERCENTAGE)
  value       Int          // percentage (1-100) or cents
  minOrder    Int?         // minimum order in cents
  maxUses     Int?
  usedCount   Int          @default(0)
  active      Boolean      @default(true)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())

  @@map("discount_codes")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  body      String?  @db.Text
  approved  Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("reviews")
}

// ─── Affiliate System (Package C) ────────────────────────────────────────────

model Affiliate {
  id            String          @id @default(cuid())
  userId        String          @unique
  code          String          @unique
  commissionRate Float          @default(0.10) // 10%
  status        AffiliateStatus @default(PENDING)
  paypalEmail   String?
  bankInfo      String?         @db.Text // encrypted
  totalEarned   Int             @default(0) // in cents
  totalPaid     Int             @default(0) // in cents
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks        AffiliateClick[]
  commissions   AffiliateCommission[]
  links         AffiliateLink[]
  payouts       AffiliatePayout[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("affiliates")
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model AffiliateLink {
  id          String    @id @default(cuid())
  affiliateId String
  name        String
  slug        String    @unique
  url         String    // destination URL
  active      Boolean   @default(true)
  clicks      Int       @default(0)
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("affiliate_links")
}

model AffiliateClick {
  id          String    @id @default(cuid())
  affiliateId String
  ip          String
  userAgent   String?
  referrer    String?
  sessionId   String
  converted   Boolean   @default(false)
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("affiliate_clicks")
}

model AffiliateCommission {
  id          String             @id @default(cuid())
  affiliateId String
  orderId     String
  amount      Int                // in cents
  status      CommissionStatus   @default(PENDING)
  affiliate   Affiliate          @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  @@map("affiliate_commissions")
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model AffiliatePayout {
  id          String    @id @default(cuid())
  affiliateId String
  amount      Int       // in cents
  method      String    // paypal | wire
  reference   String?
  notes       String?
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("affiliate_payouts")
}

// ─── AI Chat (Package D) ─────────────────────────────────────────────────────

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  sessionId String        @unique
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // user | assistant
  content   String      @db.Text
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}

// ─── Shipping Rules ───────────────────────────────────────────────────────────

model ShippingZone {
  id          String         @id @default(cuid())
  name        String
  countries   String[]
  rates       ShippingRate[]
  active      Boolean        @default(true)

  @@map("shipping_zones")
}

model ShippingRate {
  id            String       @id @default(cuid())
  zoneId        String
  name          String       // e.g. "Standard", "Express"
  price         Int          // in cents
  minWeight     Float?
  maxWeight     Float?
  minOrderValue Int?         // free shipping threshold
  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("shipping_rates")
}

// ─── Site Settings ────────────────────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── Membership Pre-Signups ──────────────────────────────────────────────────

model MembershipSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  plan      String   @default("monthly") // monthly, quarterly, annual
  source    String?  // where they signed up from (hero, product, nav, etc)
  createdAt DateTime @default(now())

  @@map("membership_signups")
}
