generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  addresses     Address[]
  reviews       Review[]
  affiliate     Affiliate?
  sessions      Session[]
  accounts      Account[]
  cartItems     CartItem[]
  orgMemberships OrgMember[]
  orgClients     OrgClient[]
  loyalty       LoyaltyAccount?
  storeCredit   StoreCredit?
  supportTickets SupportTicket[]
  membership    Membership?
  refundsCreated Refund[]    @relation("RefundCreatedBy")

  verifyToken      String?   @unique
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  twoFASecret      String?
  twoFAEnabled     Boolean   @default(false)
  birthday         DateTime?

  @@map("users")
}

enum UserRole {
  CUSTOMER
  AFFILIATE
  ADMIN
}

// ─── Organizations & Tenancy ────────────────────────────────────────────────

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  type      OrgType
  status    OrgStatus @default(ACTIVE)
  // 4-6 digit PIN that protects the "Exit kiosk" button on this org's
  // iPad displays. Null = exit is unprotected (default for orgs that
  // haven't set one). Stored as plaintext intentionally — it's a curious-
  // customer guard, not a security boundary; the real auth lives at
  // /admin via NextAuth.
  kioskPin  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  locations     Location[]
  members       OrgMember[]
  clients       OrgClient[]
  pricingPlans  PricingPlan[]
  orders        Order[]

  @@map("organizations")
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  zip            String?
  phone          String?
  commissionRate Float    @default(0.10)
  pricingPlanId  String?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingPlan    PricingPlan? @relation(fields: [pricingPlanId], references: [id])
  devices        LocationDevice[]
  orders         Order[]
  clients        OrgClient[]
  members        OrgMember[]
  commissions    OrderCommission[]

  @@unique([organizationId, slug])
  @@map("locations")
}

model OrgMember {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           OrgMemberRole
  locationId     String?

  // Personal trainer/coach referral code — used by /join?t=<code> to attribute
  // new customer signups to this trainer. Optional because OWNER/ADMIN don't
  // typically need one; auto-generated for STAFF/COACH/DOCTOR on creation.
  referralCode   String?      @unique

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  location       Location?    @relation(fields: [locationId], references: [id])

  attributedClients OrgClient[] @relation("TrainerAttributedClients")

  @@unique([organizationId, userId])
  @@index([referralCode])
  @@map("org_members")
}

model OrgClient {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  locationId     String?
  status         ClientStatus @default(ACTIVE)

  // Trainer / coach attribution — which OrgMember "owns" this client.
  // Lifetime — set on first attribution and survives unless admin reassigns.
  trainerOrgMemberId String?
  trainer            OrgMember? @relation("TrainerAttributedClients", fields: [trainerOrgMemberId], references: [id], onDelete: SetNull)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  location       Location?    @relation(fields: [locationId], references: [id])
  orders         Order[]

  @@unique([organizationId, userId])
  @@index([trainerOrgMemberId])
  @@map("org_clients")
}

model LocationDevice {
  id         String   @id @default(cuid())
  locationId String
  name       String
  apiKey     String   @unique
  lastSeenAt DateTime?

  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("location_devices")
}

model PricingPlan {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  baseDiscountPct Float?

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  overrides      ProductPriceOverride[]
  locations      Location[]

  @@unique([organizationId, name])
  @@map("pricing_plans")
}

model ProductPriceOverride {
  id            String   @id @default(cuid())
  pricingPlanId String
  productId     String
  price         Int

  pricingPlan   PricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([pricingPlanId, productId])
  @@map("product_price_overrides")
}

model OrderCommission {
  id          String            @id @default(cuid())
  orderId     String
  locationId  String
  amount      Int
  status      CommissionStatus @default(PENDING)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([orderId, locationId])
  @@map("order_commissions")
}

enum OrgType {
  GYM
  CLINIC
  DOCTOR_OFFICE
  OTHER
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum OrgMemberRole {
  OWNER
  ADMIN
  STAFF
  COACH
  DOCTOR
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Products ────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String        @db.Text
  shortDesc     String?
  price         Int           // in cents
  comparePrice  Int?          // original/strikethrough price
  salePrice     Int?          // overrides price when set (sale event)
  cost          Int?          // cost of goods
  sku           String?       @unique
  barcode       String?
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  inventory     Int           @default(0)
  trackInventory Boolean      @default(true)
  weight        Float?        // in grams
  status        ProductStatus @default(DRAFT)
  featured      Boolean       @default(false)
  seoTitle      String?
  seoDesc       String?
  tags          String[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  reviews       Review[]
  priceOverrides ProductPriceOverride[]
  facilities    ProductFacility[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("products")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String  // e.g. "10mg / 30 vials"
  sku       String?
  price     Int     // in cents
  inventory Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// ─── Cart ────────────────────────────────────────────────────────────────────

model CartItem {
  id        String  @id @default(cuid())
  userId    String?
  sessionId String? // for guest carts
  productId String
  variantId String?
  quantity  Int     @default(1)
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_items")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  email           String
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?     // stripe | crypto
  paymentId       String?     // stripe payment intent or crypto charge id
  subtotal        Int         // in cents
  discount        Int         @default(0)
  shipping        Int         @default(0)
  tax             Int         @default(0)
  total           Int         // in cents
  discountCode    String?
  notes           String?
  items           OrderItem[]
  shippingAddress Address?    @relation(fields: [shippingAddressId], references: [id])
  shippingAddressId String?
  trackingNumber  String?
  trackingUrl     String?
  affiliateCode   String?
  affiliateId     String?
  organizationId String?
  locationId     String?
  clientId       String?
  salesChannel   OrderChannel @default(DIRECT)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  location       Location?     @relation(fields: [locationId], references: [id])
  client         OrgClient?    @relation(fields: [clientId], references: [id])
  commissions    OrderCommission[]
  fulfillments   Fulfillment[]
  refunds        Refund[]
  storeCreditUsed Int          @default(0)
  loyaltyPointsUsed Int        @default(0)
  loyaltyPointsEarned Int      @default(0)

  @@map("orders")
  @@index([organizationId])
  @@index([locationId])
  @@index([clientId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum OrderChannel {
  DIRECT
  LOCATION_KIOSK
  CLIENT_PORTAL
  ADMIN
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String  // snapshot at time of purchase
  sku       String?
  price     Int     // in cents, snapshot
  quantity  Int
  total     Int     // in cents
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  fulfillmentItems FulfillmentItem[]

  @@map("order_items")
}

// ─── Refunds ─────────────────────────────────────────────────────────────────
// First-class refund record. Created by admin from /admin/orders/[id]. Cash
// refunds (Chase / Stripe) and store-credit refunds both write a row here so
// the P&L on /admin can sum a single source of truth instead of inferring
// from StoreCreditTxn for credit-only refunds.
model Refund {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount      Int          // in cents — always positive
  method      RefundMethod @default(STORE_CREDIT)
  reason      String?      @db.Text
  // External processor reference (Chase orbital ID / Stripe refund ID / store
  // credit txn id). Null until the actual refund is initiated.
  externalRef String?
  status      RefundStatus @default(PENDING)
  // Admin who initiated. Null when triggered by an automated webhook flow.
  createdById String?
  createdBy   User?        @relation("RefundCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  @@index([orderId])
  @@index([createdAt])
  @@map("refunds")
}

enum RefundMethod {
  CASH           // back to original payment method (card)
  STORE_CREDIT   // issued as store credit
  MANUAL         // recorded out-of-band (check, ACH, etc.)
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

// ─── Addresses ───────────────────────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  name       String
  line1      String
  line2      String?
  city       String
  state      String
  zip        String
  country    String  @default("US")
  phone      String?
  isDefault  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@map("addresses")
}

// ─── Discount Codes ──────────────────────────────────────────────────────────

model DiscountCode {
  id          String       @id @default(cuid())
  code        String       @unique
  type        DiscountType @default(PERCENTAGE)
  value       Int          // percentage (1-100) or cents
  minOrder    Int?         // minimum order in cents
  maxUses     Int?
  usedCount   Int          @default(0)
  active      Boolean      @default(true)
  expiresAt   DateTime?
  rule        CouponRule?
  createdAt   DateTime     @default(now())

  @@map("discount_codes")
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
  BOGO
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  body      String?  @db.Text
  approved  Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("reviews")
}

// ─── Affiliate System (Package C) ────────────────────────────────────────────

model Affiliate {
  id            String          @id @default(cuid())
  userId        String          @unique
  code          String          @unique
  commissionRate Float          @default(0.10) // 10%
  status        AffiliateStatus @default(PENDING)
  paypalEmail   String?
  bankInfo      String?         @db.Text // encrypted
  totalEarned   Int             @default(0) // in cents
  totalPaid     Int             @default(0) // in cents
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks        AffiliateClick[]
  commissions   AffiliateCommission[]
  links         AffiliateLink[]
  payouts       AffiliatePayout[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("affiliates")
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model AffiliateLink {
  id          String    @id @default(cuid())
  affiliateId String
  name        String
  slug        String    @unique
  url         String    // destination URL
  active      Boolean   @default(true)
  clicks      Int       @default(0)
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("affiliate_links")
}

model AffiliateClick {
  id          String    @id @default(cuid())
  affiliateId String
  ip          String
  userAgent   String?
  referrer    String?
  sessionId   String
  converted   Boolean   @default(false)
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("affiliate_clicks")
}

model AffiliateCommission {
  id          String             @id @default(cuid())
  affiliateId String
  orderId     String
  amount      Int                // in cents
  status      CommissionStatus   @default(PENDING)
  affiliate   Affiliate          @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  @@map("affiliate_commissions")
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model AffiliatePayout {
  id          String    @id @default(cuid())
  affiliateId String
  amount      Int       // in cents
  method      String    // paypal | wire
  reference   String?
  notes       String?
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("affiliate_payouts")
}

// ─── AI Chat (Package D) ─────────────────────────────────────────────────────

model ChatSession {
  id        String        @id @default(cuid())
  userId    String?
  sessionId String        @unique
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // user | assistant
  content   String      @db.Text
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@map("chat_messages")
}

// ─── Shipping Rules ───────────────────────────────────────────────────────────

model ShippingZone {
  id          String         @id @default(cuid())
  name        String
  countries   String[]
  rates       ShippingRate[]
  active      Boolean        @default(true)

  @@map("shipping_zones")
}

model ShippingRate {
  id            String       @id @default(cuid())
  zoneId        String
  name          String       // e.g. "Standard", "Express"
  price         Int          // in cents
  minWeight     Float?
  maxWeight     Float?
  minOrderValue Int?         // free shipping threshold
  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("shipping_rates")
}

// ─── Site Settings ────────────────────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── Membership Pre-Signups ──────────────────────────────────────────────────

model MembershipSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  plan      String   @default("monthly") // monthly, quarterly, annual
  source    String?  // where they signed up from (hero, product, nav, etc)
  createdAt DateTime @default(now())

  @@map("membership_signups")
}

// ─── Fulfillment Facilities (licensed Florida labs) ──────────────────────────

model Facility {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  contactName String?
  email       String
  phone       String?
  addressLine1 String
  addressLine2 String?
  city        String
  state       String   @default("FL")
  zip         String
  country     String   @default("US")
  licenseNumber String?
  apiEndpoint String?  // supplier API base URL
  apiKey      String?  // encrypted credentials
  active      Boolean  @default(true)
  slaHours    Int      @default(48) // fulfillment SLA
  notes       String?  @db.Text
  products    ProductFacility[]
  fulfillments Fulfillment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("facilities")
}

model ProductFacility {
  id         String   @id @default(cuid())
  productId  String
  facilityId String
  primary    Boolean  @default(false) // default facility for this product
  cost       Int?     // wholesale cost in cents
  inventory  Int      @default(0)     // facility-tracked inventory
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([productId, facilityId])
  @@map("product_facilities")
}

model Fulfillment {
  id             String             @id @default(cuid())
  orderId        String
  facilityId     String
  status         FulfillmentStatus  @default(PENDING)
  externalId     String?            // supplier's order reference
  trackingNumber String?
  trackingUrl    String?
  carrier        String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  notes          String?            @db.Text
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  facility       Facility           @relation(fields: [facilityId], references: [id])
  items          FulfillmentItem[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("fulfillments")
  @@index([orderId])
  @@index([facilityId])
  @@index([status])
}

model FulfillmentItem {
  id            String      @id @default(cuid())
  fulfillmentId String
  orderItemId   String
  quantity      Int
  fulfillment   Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id])

  @@map("fulfillment_items")
}

enum FulfillmentStatus {
  PENDING
  ACCEPTED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

// ─── Loyalty & Rewards ──────────────────────────────────────────────────────

model LoyaltyAccount {
  id          String              @id @default(cuid())
  userId      String              @unique
  tier        LoyaltyTier         @default(BRONZE)
  points      Int                 @default(0)
  lifetimeSpend Int               @default(0) // cents
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("loyalty_accounts")
}

enum LoyaltyTier {
  BRONZE    // default
  SILVER    // $500+ lifetime
  GOLD      // $2000+ lifetime
  PLATINUM  // $5000+ lifetime
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String
  type        LoyaltyTxType
  points      Int            // positive for earn, negative for redeem
  description String
  orderId     String?        // if tied to an order
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@map("loyalty_transactions")
}

enum LoyaltyTxType {
  EARN_PURCHASE
  EARN_REFERRAL
  EARN_REVIEW
  EARN_BIRTHDAY
  EARN_ADMIN    // manual admin grant
  REDEEM_DISCOUNT
  EXPIRE
  ADJUST        // admin adjustment
}

// ─── Store Credit ───────────────────────────────────────────────────────────

model StoreCredit {
  id          String             @id @default(cuid())
  userId      String             @unique
  balance     Int                @default(0) // cents
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions StoreCreditTxn[]
  updatedAt   DateTime           @updatedAt

  @@map("store_credits")
}

model StoreCreditTxn {
  id          String      @id @default(cuid())
  creditId    String
  type        CreditTxType
  amount      Int         // positive for credit, negative for debit (cents)
  description String
  orderId     String?
  credit      StoreCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@map("store_credit_txns")
}

enum CreditTxType {
  REFUND
  REFERRAL_BONUS
  ADMIN_GRANT
  BIRTHDAY
  LOYALTY_REDEEM
  CHECKOUT_APPLY  // used at checkout
  EXPIRE
}

// ─── Product Reviews (ENABLED via existing Review model) ────────────────────
// Review model already exists at line ~460

// ─── Support Tickets ────────────────────────────────────────────────────────

model SupportTicket {
  id          String          @id @default(cuid())
  number      String          @unique // e.g. VP-TKT-000001
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String
  subject     String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(NORMAL)
  orderId     String?         // if related to an order
  assignedTo  String?         // admin user id
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("support_tickets")
  @@index([status])
  @@index([userId])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  authorId   String?       // null = customer, set = admin
  authorName String
  body       String        @db.Text
  internal   Boolean       @default(false) // admin notes not visible to customer
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@map("ticket_messages")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── Newsletter & Marketing ─────────────────────────────────────────────────

model NewsletterSubscriber {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  source       String?
  confirmed    Boolean   @default(false)
  confirmToken String?
  unsubscribed Boolean   @default(false)
  tags         String[]
  createdAt    DateTime  @default(now())

  @@map("newsletter_subscribers")
}

model CartAbandonment {
  id         String   @id @default(cuid())
  userId     String?
  email      String?
  cartJson   String   @db.Text
  subtotal   Int
  emailSent  Boolean  @default(false)
  emailedAt  DateTime?
  recovered  Boolean  @default(false)
  recoveredAt DateTime?
  createdAt  DateTime @default(now())

  @@map("cart_abandonments")
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String   // e.g. "order.refund", "product.update", "user.login"
  entityType String?  // e.g. "Order", "Product"
  entityId   String?
  metadata   String?  @db.Text // JSON
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
  @@index([action])
  @@index([userId])
  @@index([entityType, entityId])
}

// ─── Admin Notifications ────────────────────────────────────────────────────

model AdminNotification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  body        String           @db.Text
  link        String?          // admin path to view details
  entityType  String?
  entityId    String?
  readBy      String[]         // admin user ids who've read
  createdAt   DateTime         @default(now())

  @@map("admin_notifications")
  @@index([createdAt])
}

enum NotificationType {
  ORDER_NEW
  ORDER_REFUND_REQUEST
  APPLICATION_NEW
  LOW_STOCK
  FULFILLMENT_DELAYED
  SUPPORT_TICKET_NEW
  SYSTEM
}

// ─── Page Views / Analytics ─────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  sessionId String
  referrer  String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  @@map("page_views")
  @@index([path, createdAt])
  @@index([sessionId])
}

// ─── Enhanced Coupons (supplement DiscountCode) ─────────────────────────────

model CouponRule {
  id                 String       @id @default(cuid())
  discountCodeId     String       @unique
  minOrderCents      Int?
  productIds         String[]     // specific products
  categoryIds        String[]     // specific categories
  customerIds        String[]     // specific customers
  newCustomersOnly   Boolean      @default(false)
  membersOnly        Boolean      @default(false)
  tierRequired       LoyaltyTier?
  stackable          Boolean      @default(false)
  autoApply          Boolean      @default(false)
  firstPurchaseOnly  Boolean      @default(false)
  usesPerCustomer    Int?
  discountCode       DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@map("coupon_rules")
}

// ─── CRM: Customer Notes, Tags, Tasks ───────────────────────────────────────

model CustomerNote {
  id         String   @id @default(cuid())
  userId     String
  authorId   String   // admin user id
  authorName String
  body       String   @db.Text
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("customer_notes")
  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6270f2")
  createdAt DateTime @default(now())
  users     UserTag[]

  @@map("tags")
}

model UserTag {
  userId    String
  tagId     String
  taggedBy  String?  // admin user id
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@map("user_tags")
  @@index([userId])
  @@index([tagId])
}

model AdminTask {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.Text
  status      TaskStatus  @default(PENDING)
  priority    TaskPriority @default(NORMAL)
  dueAt       DateTime?
  assignedTo  String?     // admin user id
  createdBy   String
  // Related entity (optional)
  entityType  String?     // "User" | "Order" | "Organization" | "Ticket"
  entityId    String?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("admin_tasks")
  @@index([assignedTo])
  @@index([status])
  @@index([dueAt])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── CRM: Outbound Communications ───────────────────────────────────────────

model OutboundMessage {
  id          String           @id @default(cuid())
  userId      String?          // customer
  toEmail     String?
  toPhone     String?
  channel     MessageChannel
  direction   String           @default("outbound")
  subject     String?
  body        String           @db.Text
  sentById    String?          // admin user id (null = system)
  sentByName  String?
  status      MessageStatus    @default(SENT)
  providerId  String?          // resend id / twilio sid
  openedAt    DateTime?
  clickedAt   DateTime?
  bouncedAt   DateTime?
  errorMsg    String?
  // Optional linkage
  campaignId  String?
  campaign    MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  @@map("outbound_messages")
  @@index([userId])
  @@index([toEmail])
  @@index([campaignId])
  @@index([status])
}

enum MessageChannel {
  EMAIL
  SMS
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

// ─── CRM: Marketing Campaigns ───────────────────────────────────────────────

model MarketingCampaign {
  id             String              @id @default(cuid())
  name           String
  channel        MessageChannel      @default(EMAIL)
  subject        String?
  body           String              @db.Text // HTML for email, plain for SMS
  segmentId     String?
  segment        SavedSegment?       @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  status         CampaignStatus      @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  // Stats
  recipientCount Int                 @default(0)
  deliveredCount Int                 @default(0)
  openedCount    Int                 @default(0)
  clickedCount   Int                 @default(0)
  bouncedCount   Int                 @default(0)
  conversions    Int                 @default(0)   // tied to orders
  revenueCents   Int                 @default(0)
  messages       OutboundMessage[]
  createdBy      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("marketing_campaigns")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

// ─── CRM: Saved Segments ────────────────────────────────────────────────────

model SavedSegment {
  id          String              @id @default(cuid())
  name        String
  description String?
  filters     String              @db.Text // JSON: { minSpent, maxSpent, tagIds[], tier, hasOrderedIn[days], state, etc }
  createdBy   String
  campaigns   MarketingCampaign[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("saved_segments")
}

// ─── CRM: Sales Leads (B2B Pipeline) ────────────────────────────────────────

model SalesLead {
  id             String     @id @default(cuid())
  organizationId String?    @unique // once they apply it links to the org
  businessName   String
  contactName    String
  contactEmail   String
  contactPhone   String?
  source         String?    // "website", "tradeshow", "referral", "cold_outreach"
  stage          LeadStage  @default(NEW)
  priority       LeadPriority @default(NORMAL)
  estimatedValue Int?       // cents — expected monthly revenue
  probability    Int?       // 0-100
  assignedTo     String?    // admin user id
  notes          String?    @db.Text
  nextAction     String?
  nextActionDue  DateTime?
  closedAt       DateTime?
  closedReason   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("sales_leads")
  @@index([stage])
  @@index([assignedTo])
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum LeadPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── CRM: Communication Preferences ─────────────────────────────────────────

model CommunicationPreference {
  userId          String   @id
  transactionalEmail Boolean @default(true)
  marketingEmail  Boolean  @default(true)
  sms             Boolean  @default(false)
  phoneContact    Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@map("communication_preferences")
}

// ─── Membership Tiers (Vitality Club) ───────────────────────────────────────

model Membership {
  id                            String         @id @default(cuid())
  userId                        String         @unique
  tier                          MembershipTier @default(NONE)
  status                        String         @default("ACTIVE") // ACTIVE / PAUSED / CANCELLED
  monthlyPriceCents             Int            @default(0)
  startedAt                     DateTime       @default(now())
  renewsAt                      DateTime?
  cancelledAt                   DateTime?
  // Free peptide credits earned per billing period (Plus = 1, Premium = 3)
  freePeptideCreditsThisPeriod  Int            @default(0)
  freePeptidesUsedThisPeriod    Int            @default(0)
  // Stripe-style subscription tracking — Chase will go here when ready
  externalSubscriptionId        String?
  paymentProvider               String?        // 'chase', 'stripe', etc.
  user                          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  @@map("memberships")
}

enum MembershipTier {
  NONE
  CLUB     // $25/mo
  PLUS     // $150/mo
  PREMIUM  // $300/mo
}
