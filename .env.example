# Database (use Neon, Supabase, or Vercel Postgres for Vercel deployments)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Anthropic AI (for Vita chat widget)
ANTHROPIC_API_KEY="sk-ant-..."

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_BASE_DOMAIN="vitalityproject.global"

# Auth cookie domain for subdomain SSO (set to ".vitalityproject.global" in prod)
NEXTAUTH_COOKIE_DOMAIN=""

# Payment — Chase Merchant Processing
CHASE_API_KEY=""
CHASE_MERCHANT_ID=""

# Redis (optional — for rate limiting in production)
REDIS_URL="redis://localhost:6379"

# Affiliate tracking
AFFILIATE_COOKIE_DAYS=30

# Email — Resend (https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="The Vitality Project <noreply@vitalityproject.global>"
EMAIL_REPLY_TO="support@vitalityproject.global"
# Where admin-alert emails (new orders, business applications, low stock) are sent
ADMIN_EMAIL="admin@vitalityproject.global"
