# Database (use Neon, Supabase, or Vercel Postgres for Vercel deployments)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Anthropic AI (for Vita chat widget)
ANTHROPIC_API_KEY="sk-ant-..."

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Payment (Zelle email — set when company info is finalized)
ZELLE_EMAIL="payments@thevitalityproject.com"

# Redis (optional — for rate limiting in production)
REDIS_URL="redis://localhost:6379"

# Affiliate tracking
AFFILIATE_COOKIE_DAYS=30
